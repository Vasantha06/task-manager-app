<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="background-color: #f0fdf4;" class="text-white"></body>
<nav class="navbar navbar-dark bg-dark mb-4"
     style="background-color:  #16a34a;">
  <div class="container d-flex justify-content-between">
    <span class="navbar-brand ">Task Manager</span>
    <a href="/logout" class="btn btn-danger btn-sm">Logout</a>
  </div>
</nav>
<div class="container mt-5">

    <div class="d-flex justify-content-between mb-4 text-black">
        <h2>Dashboard 🚀</h2>
     
    </div>

    <!-- Add Task -->
    <div class="card p-3 mb-4">
        <h4>Add Task</h4>
        <form action="/add-task" method="POST">
            <input class="form-control mb-2" type="text" name="title" placeholder="Title" required>
            <input class="form-control mb-2" type="text" name="description" placeholder="Description">
            <input class="form-control mb-2" type="date" name="dueDate">
            <button class="btn text-white"
                    style="background-color: #16a34a;">Add Task</button>
        </form>
    </div>
    
    
    

    <!-- 📊 Filter -->
    <form method="GET" action="/dashboard" class="row mb-3">
    <div class="col-md-6">
        <input type="text" name="search" class="form-control" placeholder="Search tasks...">
    </div>
    <div class="col-md-4">
        <select name="status" class="form-control">
            <option value="">All</option>
            <option value="Pending">Pending</option>
            <option value="Completed">Completed</option>
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-dark w-100">Apply</button>
    </div>
</form>

    <!-- Tasks -->
    <div class="row">
        <% tasks.forEach(task => { %>
            <div class="col-md-4">
                 <div class="card mb-3 shadow bg-white text-dark
                  <%= task.dueDate && new Date(task.dueDate) < new Date() && task.status !== 'Completed' ? 'border-danger' : '' %>">
                    <div class="card-body">

                        <h5><%= task.title %></h5>
                        <p><%= task.description %></p>

                        <p>
                            Status:
                            <span class="badge 
                                <%= task.status === 'Completed' ? 'bg-success' : 'bg-warning' %>">
                                <%= task.status %>
                            </span>
                        </p>

                        <p>Due: <%= task.dueDate ? task.dueDate.toDateString() : "No date" %></p>

                        <a href="/update/<%= task._id %>" class="btn btn-success btn-sm">Complete</a>
                        <a href="/edit/<%= task._id %>" class="btn btn-primary btn-sm">Edit</a>
                        <a href="/delete/<%= task._id %>" class="btn btn-danger btn-sm">Delete</a>

                    </div>
                </div>
            </div>
        <% }) %>
    </div>

</div>

</body>
</html>