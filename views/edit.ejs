<!DOCTYPE html>
<html>
<head>
    <title>Edit Task</title>
</head>
<body>

<h2>Edit Task</h2>

<form action="/edit/<%= task._id %>" method="POST">
    <input type="text" name="title" value="<%= task.title %>" required><br>
    <input type="text" name="description" value="<%= task.description %>"><br>
    <input type="date" name="dueDate" value="<%= task.dueDate ? task.dueDate.toISOString().split('T')[0] : '' %>"><br>
    <button type="submit">Update</button>
</form>

<a href="/dashboard">Back</a>

</body>
</html>